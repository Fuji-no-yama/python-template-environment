FROM python:3.13
USER root

# uvとtyのインストール
COPY --from=ghcr.io/astral-sh/uv:latest /uv /bin
# codex CLI 用の Node.js を公式イメージから取り込む
COPY --from=node:20-bookworm /usr/local/ /usr/local/
# COPY --from=ghcr.io/astral-sh/ty:latest /ty /bin  # 現時点で動かないためコメントアウト

RUN apt-get update && \
    pip install --upgrade pip && \
    apt-get install -y git && \
    npm install -g @openai/codex && \
    npm cache clean --force


WORKDIR /workspace

# その他便利ツールのインストール
# RUN apt-get -y install --reinstall ca-certificates && \
#     apt-get -y install software-properties-common && \
#     apt-get install -y sudo wget vim curl gawk make gcc && \
#     apt-get install -y graphviz xdg-utils && \
#     apt-get install iputils-ping net-tools
